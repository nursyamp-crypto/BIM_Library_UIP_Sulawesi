generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String    @unique
  password  String
  role      String    @default("USER") // ADMIN or USER
  avatar    String?
  approved  Boolean   @default(false)
  fullName   String?
  birthPlace String?
  birthDate  DateTime?
  address    String?
  division   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  models    Model3D[]
  comments  Comment[]
  auditLogs AuditLog[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  modelId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  model     Model3D  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Model3D {
  id            String    @id @default(uuid())
  title         String
  description   String    @default("")
  fileName      String
  originalName  String
  filePath      String
  fileSize      Int
  fileFormat    String
  thumbnailPath String?
  downloadCount Int       @default(0)
  latitude      Float?
  longitude     Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])

  uploaderId    String
  uploader      User      @relation(fields: [uploaderId], references: [id])

  tags          ModelTag[]
  comments      Comment[]
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String    @default("")
  createdAt   DateTime  @default(now())

  models      Model3D[]
}

model Tag {
  id   String     @id @default(uuid())
  name String     @unique

  models ModelTag[]
}

model ModelTag {
  modelId String
  tagId   String
  model   Model3D @relation(fields: [modelId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([modelId, tagId])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  targetType String
  targetId   String?
  details    String   @default("")
  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
}
